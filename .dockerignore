# .dockerignore  (project root)
#
# Keeps the Docker build context lean.
# Without this, Docker sends your entire venv and cache to the daemon.

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Development tools
.git/
.gitignore
.pytest_cache/
.mypy_cache/
.ruff_cache/
.idea/
.vscode/
*.iml

# Test and scratch files
scratch_*.py
tests/
htmlcov/
.coverage

# OS
.DS_Store
Thumbs.db

# Logs
*.log
*.output/
logs/

# Keep data/ — the container needs pass_windows.json and scenario files
# Keep src/ — the environment source code
# Keep scripts/ — generate_windows.py (not needed at runtime but small)
